rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /links/{code} {
      // anyone can look up a single code (thats how the redirect works in the browser).
      // but no listing the whole collection, and only i can create/edit/delete.
      allow get: if true;
      allow list: if request.auth != null && request.auth.uid == 'MODyWf0INhVaRwYnlJ4mLujH5ld2';
      allow write: if request.auth != null && request.auth.uid == 'MODyWf0INhVaRwYnlJ4mLujH5ld2';
    }
  }
}
